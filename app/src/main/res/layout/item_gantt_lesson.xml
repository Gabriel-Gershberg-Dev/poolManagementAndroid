<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardGantt"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="@dimen/spacing_xs"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/border_color"
    app:cardBackgroundColor="@color/card_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <View
            android:id="@+id/accentBar"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:minHeight="48dp"
            android:background="@color/instructor_yotam" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_md"
            android:paddingEnd="@dimen/spacing_sm"
            android:paddingTop="@dimen/spacing_md"
            android:paddingBottom="@dimen/spacing_md">

            <TextView
                android:id="@+id/tvGanttTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:textColor="?attr/colorOnSurface"
                tools:text="Yotam – Freestyle (Private)" />

            <TextView
                android:id="@+id/tvGanttTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="Monday 16:00 – 45 min" />

            <TextView
                android:id="@+id/tvGanttStudents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:maxLines="3"
                android:ellipsize="end"
                tools:text="John Doe, Jane Smith" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeleteLesson"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center_vertical"
            app:icon="@drawable/ic_delete"
            app:iconSize="22dp"
            app:iconTint="?attr/colorError" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
